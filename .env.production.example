# ═══════════════════════════════════════════════════════════════════════════
# SKALLE — Exemple d'environnement PRODUCTION (Vercel / déploiement)
# ═══════════════════════════════════════════════════════════════════════════
# Utilisation :
#   1. Copier ce fichier et remplir les valeurs réelles (ne pas commiter les secrets).
#   2. Sur Vercel : Settings → Environment Variables → coller chaque variable.
#   3. Redéployer après avoir ajouté les variables.
# ═══════════════════════════════════════════════════════════════════════════

# ── URL de l'app (production) ─────────────────────────────────────────────
# Remplacer par ton domaine Vercel ou custom
NEXTAUTH_URL="https://skalle.vercel.app"
AUTH_URL="https://skalle.vercel.app"

# ── Secrets (à générer / récupérer, ne pas réutiliser les valeurs de dev) ─
# openssl rand -base64 32
AUTH_SECRET="VOTRE_SECRET_PRODUCTION_32_CARACTERES_MIN"
# openssl rand -hex 32
ENCRYPTION_KEY="64_caracteres_hex_pour_chiffrement_smtp_etc"

# ── Base de données (Supabase ou autre PostgreSQL) ────────────────────────
# Poolée (PgBouncer, port 6543) pour l'app
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[MOT_DE_PASSE]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Directe (port 5432) pour les migrations
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[MOT_DE_PASSE]@aws-0-eu-west-3.pooler.supabase.com:5432/postgres"

# ── Auth (au moins un provider pour la connexion) ─────────────────────────
# Option 1 : Google OAuth (Google Cloud Console → Credentials)
GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxx"

# Option 2 : GitHub (GitHub → Settings → Developer settings → OAuth Apps)
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""

# Option 3 : Facebook
# FACEBOOK_CLIENT_ID=""
# FACEBOOK_CLIENT_SECRET=""

# (Credentials email/mot de passe est toujours actif si configuré en base)

# ── IA (recommandé pour le fonctionnement complet) ──────────────────────────
ANTHROPIC_API_KEY="sk-ant-api03-..."
OPENAI_API_KEY="sk-proj-..."
SERPER_API_KEY=""

# ── Stripe (si abonnements activés) ───────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_PRICE_BUSINESS="price_xxx"
STRIPE_PRICE_AGENCY="price_xxx"
STRIPE_PRICE_SCALE="price_xxx"
STRIPE_PRICE_TOPUP="price_xxx"

# ── Optionnel : Redis (rate limiting multi-instance) ───────────────────────
# https://console.upstash.com
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN=""

# ── Optionnel : Emails (reset password, notifications) ─────────────────────
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="Skalle <noreply@votredomaine.com>"
# ADMIN_NOTIFY_EMAIL="admin@votredomaine.com"

# ── Optionnel : Meta / Facebook (ads, webhooks) ────────────────────────────
# META_FB_ACCESS_TOKEN=""
# META_FB_APP_ID=""
# META_FB_APP_SECRET=""
# META_APP_SECRET=""
# META_WEBHOOK_VERIFY_TOKEN=""

# ── Optionnel : Google Search Console OAuth ────────────────────────────────
# GOOGLE_GSC_CLIENT_ID=""
# GOOGLE_GSC_CLIENT_SECRET=""

# ── Optionnel : Sentry (erreurs et source maps) ────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN="https://xxx@sentry.io/xxx"
# SENTRY_DSN="..."
# SENTRY_ORG=""
# SENTRY_PROJECT=""
# SENTRY_AUTH_TOKEN=""

# ── Optionnel : Inngest (tâches planifiées) ────────────────────────────────
# INNGEST_SIGNING_KEY=""
# INNGEST_EVENT_KEY=""

# ── Optionnel : Autres ─────────────────────────────────────────────────────
# COMPANY_OFFER="Votre offre en 1-2 phrases"
# NEXT_PUBLIC_APP_VERSION="1.0.0"
# DATAFORSEO_LOGIN=""
# DATAFORSEO_PASSWORD=""
# APOLLO_API_KEY=""
# HUNTER_API_KEY=""
# SERPAPI_API_KEY=""
# DISCORD_ADMIN_WEBHOOK_URL=""
