# ══════════════════════════════════════════════════════════
# SKALLE — Variables d'environnement (template)
# Copier ce fichier en .env.local et remplir les valeurs
# NE JAMAIS commiter .env ou .env.local sur Git
# ══════════════════════════════════════════════════════════

# ── Auth.js ──────────────────────────────────────────────
# Générer avec : openssl rand -base64 32
AUTH_SECRET="CHANGE_ME_GENERATE_WITH_OPENSSL"
AUTH_URL="http://localhost:3000"

# ── OAuth Providers (optionnels, activer selon les providers voulus) ──
# Google → https://console.cloud.google.com → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub → https://github.com/settings/applications/new
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Facebook → https://developers.facebook.com → App > Settings > Basic
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# ── Chiffrement DB (secrets SMTP…) ───────────────────────
# Générer avec : openssl rand -hex 32
ENCRYPTION_KEY="CHANGE_ME_64_HEX_CHARS"

# ── Base de données (Supabase) ────────────────────────────
# DATABASE_URL  → URL poolée PgBouncer (port 6543) — utilisée par l'app
# DIRECT_URL    → URL directe (port 5432) — utilisée par prisma migrate
# Dans Supabase : Project Settings > Database > Connection string
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-west-3.pooler.supabase.com:5432/postgres"

# ── IA — Anthropic Claude ────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ── IA — OpenAI ──────────────────────────────────────────
OPENAI_API_KEY="sk-proj-..."

# ── Serper (Google Search API) ───────────────────────────
SERPER_API_KEY=""

# ── Stripe (Paiements) ───────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Price IDs Stripe (créer dans Dashboard Stripe > Products)
STRIPE_PRICE_BUSINESS="price_..."   # Abonnement récurrent €39/mois
STRIPE_PRICE_AGENCY="price_..."     # Abonnement récurrent €89/mois
STRIPE_PRICE_SCALE="price_..."      # Abonnement récurrent €249/mois
STRIPE_PRICE_TOPUP="price_..."      # Paiement one-time €19 (500 crédits)

# ── Meta / Facebook ──────────────────────────────────────
META_FB_ACCESS_TOKEN=""
META_FB_APP_ID=""
META_FB_APP_SECRET=""
META_AD_LIBRARY_COUNTRY="ALL"
# Webhook Meta (requis pour /api/webhooks/meta)
# META_APP_SECRET = identique à META_FB_APP_SECRET
META_APP_SECRET=""
# Token de vérification choisi librement lors de la config du webhook dans Meta for Developers
META_WEBHOOK_VERIFY_TOKEN=""

# ── SMTP transactionnel (reset password, vérification email) ─────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
ADMIN_NOTIFY_EMAIL=""

# ── Google Search Console (OAuth2) ───────────────────────
GOOGLE_GSC_CLIENT_ID=""
GOOGLE_GSC_CLIENT_SECRET=""

# ── SerpApi (Job Board Signals) ──────────────────────────
SERPAPI_API_KEY=""

# ── Apollo / Hunter (Auto-enrichissement prospects) ──────
APOLLO_API_KEY=""
HUNTER_API_KEY=""

# ── DataForSEO (SEO Intelligence) ────────────────────────
DATAFORSEO_LOGIN=""
DATAFORSEO_PASSWORD=""

# ── Upstash Redis (Rate limiting multi-instance) ─────────
# Créer sur https://console.upstash.com → Redis → Create database
# Copier REST URL + REST Token depuis l'onglet "REST API"
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Inngest ──────────────────────────────────────────────
INNGEST_SIGNING_KEY=""
INNGEST_EVENT_KEY=""

# ── Sentry (Error tracking) ──────────────────────────────
# Créer sur https://sentry.io → Settings > Projects > DSN
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""   # Nécessaire pour l'upload des source maps en CI/CD

# ── Discord (Notifications admin) ────────────────────────
DISCORD_ADMIN_WEBHOOK_URL=""

# ── URL publique (Vercel / production) ───────────────────
NEXTAUTH_URL="https://votredomaine.com"
NEXT_PUBLIC_APP_VERSION="1.0.0"

# ── Personnalisation IA (séquences outreach) ──────────────
# Texte décrivant votre offre, utilisé dans les scripts de prospection
COMPANY_OFFER="Décrivez votre offre en 1-2 phrases"
