{
  "framework": "nextjs",
  "regions": ["cdg1"],
  "functions": {
    "src/app/api/inngest/route.ts": {
      "maxDuration": 300
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ]
}
